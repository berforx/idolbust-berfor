---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Team, SocialLinks } from '@/components';
import { ABOUT_PAGE_CONTENT, TEAM_MEMBERS } from '@/data/about';
import type { AboutSection } from '@/data-models/about';
import { BRAND_CONFIG } from '@/data/brand';

const socialLinks = BRAND_CONFIG.links.social;
---

<BaseLayout
  title={ABOUT_PAGE_CONTENT.title}
  description={ABOUT_PAGE_CONTENT.description}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="mb-8 text-4xl font-bold text-secondary-900">
      {ABOUT_PAGE_CONTENT.hero.title}
    </h1>
    
    <div class="prose prose-secondary max-w-3xl">
      <p class="lead text-xl text-secondary-600">{ABOUT_PAGE_CONTENT.hero.body}</p>
      
      {ABOUT_PAGE_CONTENT.sections.map((section: AboutSection) => (
        <>
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </>
      ))}
    </div>

    <Team members={TEAM_MEMBERS} title={ABOUT_PAGE_CONTENT.teamTitle} />

    <div class="mt-12 flex items-center justify-center gap-4">
      <span class="text-secondary-600">{ABOUT_PAGE_CONTENT.socialLabel}</span>
      <SocialLinks links={socialLinks} />
    </div>
  </div>
</BaseLayout>
